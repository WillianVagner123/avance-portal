# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=troque_este_valor_por_um_secret_forte

# Login estático sem banco/Supabase.
# Guarde hashes bcrypt aqui ou como Secret/variável no ambiente de deploy.
# Nunca coloque senha em texto puro.
STATIC_LOGIN_EMAIL=admin@exemplo.com
STATIC_LOGIN_PASSWORD_HASH=cole_o_hash_bcrypt_aqui
STATIC_LOGIN_NAME=Administrador
STATIC_LOGIN_ROLE=MASTER
STATIC_LOGIN_STATUS=ACTIVE

# Alternativa para vários usuários:
# STATIC_USERS_JSON=[{"id":"user-1","email":"profissional@exemplo.com","name":"Profissional","passwordHash":"cole_o_hash_bcrypt_aqui","role":"PROFESSIONAL","status":"ACTIVE"}]

# Google continua opcional. Se não preencher, o provider Google não é registrado.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
